# FINISHED
[Unit]
Description=Runs executable responsible for sending Lidar via UDP.
# This ties the lifecycle of this service to the target  
After=network.target

[Service]
Type=simple
# Always use absolute paths for both the interpreter and the script
ExecStart=/home/quadconn/quadconn/scripts/bash/run_lidar.sh
WorkingDirectory=/home/quadconn/quadconn/
Restart=on-failure
User=quadconn

[Install]
# This tells systemd to start this service when the target is started
WantedBy=quadconn_startup.target  