<?xml version="1.0"?>
<robot name="mit_cheetah_single_leg">

  <!--
    Single MIT-Cheetah-style leg (3-DoF): Hip Ab/Ad, Hip Flex/Ext, Knee Flex/Ext
    - Simple primitives (boxes/cylinders) for visuals/collisions
    - Dimensions are approximate; tune link lengths, masses, inertia, and offsets to match your CAD.
    Frames:
      X forward, Y left, Z up
    Joint axes (typical):
      hip_abduction:  X (roll)
      hip:            Y (pitch)
      knee:           Y (pitch)
  -->

  <!-- ============ BASE ============ -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="3.0"/>
      <inertia ixx="0.02" iyy="0.02" izz="0.02" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ============ HIP AB/AD ============ -->
  <joint name="hip_abduction" type="revolute">
    <parent link="base_link"/>
    <child link="hip_link"/>
    <!-- hip offset from body -->
    <origin xyz="0.00 0.10 0.00" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.6" upper="0.6" effort="60" velocity="12"/>
  </joint>

  <link name="hip_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.08"/>
      </geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.08"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.6"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ============ HIP PITCH (THIGH) ============ -->
  <joint name="hip_pitch" type="revolute">
    <parent link="hip_link"/>
    <child link="thigh_link"/>
    <!-- small lateral bracket thickness -->
    <origin xyz="0.00 0.00 0.00" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.7" upper="1.2" effort="80" velocity="12"/>
  </joint>

  <link name="thigh_link">
    <!-- Approx thigh length ~0.21 m -->
    <visual>
      <origin xyz="0.105 0 -0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.21 0.035 0.035"/>
      </geometry>
      <material name="light"/>
    </visual>
    <collision>
      <origin xyz="0.105 0 -0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.21 0.035 0.035"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.105 0 -0.02" rpy="0 0 0"/>
      <mass value="0.45"/>
      <inertia ixx="0.002" iyy="0.006" izz="0.006" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ============ KNEE PITCH (SHANK) ============ -->
  <joint name="knee_pitch" type="revolute">
    <parent link="thigh_link"/>
    <child link="shank_link"/>
    <!-- knee at end of thigh -->
    <origin xyz="0.21 0 -0.02" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.6" upper="0.0" effort="80" velocity="12"/>
  </joint>

  <link name="shank_link">
    <!-- Approx shank length ~0.22 m -->
    <visual>
      <origin xyz="0.11 0 -0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.22 0.030 0.030"/>
      </geometry>
      <material name="light"/>
    </visual>
    <collision>
      <origin xyz="0.11 0 -0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.22 0.030 0.030"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.11 0 -0.02" rpy="0 0 0"/>
      <mass value="0.35"/>
      <inertia ixx="0.0015" iyy="0.004" izz="0.004" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ============ FOOT (fixed) ============ -->
  <joint name="foot_fixed" type="fixed">
    <parent link="shank_link"/>
    <child link="foot_link"/>
    <origin xyz="0.22 0 -0.02" rpy="0 0 0"/>
  </joint>

  <link name="foot_link">
    <visual>
      <origin xyz="0.035 0 -0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.07 0.020 0.020"/>
      </geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <origin xyz="0.035 0 -0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.07 0.020 0.020"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.035 0 -0.02" rpy="0 0 0"/>
      <mass value="0.08"/>
      <inertia ixx="0.0001" iyy="0.0002" izz="0.0002" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ============ MATERIALS ============ -->
  <material name="dark"><color rgba="0.25 0.25 0.25 1"/></material>
  <material name="light"><color rgba="0.75 0.75 0.75 1"/></material>

</robot>

