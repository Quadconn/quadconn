<?xml version="1.0"?>
<robot name="leg3dof">

  <!-- Root link -->
  <link name="base"/>

  <!-- First link -->
  <link name="link1"/>
  <!-- Second link -->
  <link name="link2"/>
  <!-- Third link -->
  <link name="link3"/>
  <!-- End-effector -->
  <link name="foot"/>

  <!-- 'effort' and 'velocity' parameters of 'limit' are ignored -->

  <!-- Joint 1 -->
  <joint name="joint1" type="revolute">
    <parent link="base"/>
    <child  link="link1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="1" velocity="1"/>
  </joint>

  <!-- Joint 2 -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child  link="link2"/>
    <origin xyz="0 0 -0.2" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="1" velocity="1"/>
  </joint>

  <!-- Joint 3 -->
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child  link="link3"/>
    <origin xyz="0 0 -0.2" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="1" velocity="1"/>
  </joint>

  <!-- Fixed "foot" -->
  <joint name="foot_fixed" type="fixed">
    <parent link="link3"/>
    <child  link="foot"/>
    <origin xyz="0 0 -0.2"/>
  </joint>

</robot>

