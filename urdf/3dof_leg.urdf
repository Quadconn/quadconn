<?xml version="1.0"?>
<robot name="leg3dof">

  <!-- First link -->
  <link name="link1"/>
  <!-- Second link -->
  <link name="link2"/>
  <!-- Third link -->
  <link name="link3"/>
  <!-- End-effector -->
  <link name="foot"/>

  <!-- 'effort' and 'velocity' parameters of 'limit' are ignored -->

  <!-- Joint 1 -->
  <joint name="joint1" type="revolute">
    <parent link="link1"/>
    <child  link="link2"/>

    <origin xyz="0.2235 0.04241 0" rpy="0 0 0"/>

    <axis xyz="1 0 0"/>

    <limit lower="-3.14" upper="3.14" effort="1" velocity="1"/>
  </joint>

  <!-- Joint 2 -->
  <joint name="joint2" type="revolute">
    <parent link="link2"/>
    <child  link="link3"/>

    <origin xyz="0.19425 0.069 0" rpy="0 0 0"/>

    <axis xyz="0 1 0"/>

    <limit lower="-3.14" upper="3.14" effort="1" velocity="1"/>
  </joint>

  <!-- Joint 3 -->
  <joint name="joint3" type="revolute">
    <parent link="link3"/>
    <child  link="foot"/>

    <origin xyz="0.140 0 0" rpy="0 0 0"/>

    <axis xyz="0 1 0"/>

    <limit lower="-3.14" upper="3.14" effort="1" velocity="1"/>
  </joint>

</robot>

