<?xml version="1.0"?>
<robot name="basic_quad" xmlns:xacro="http://www.ros.org/wiki/xacro">

<!-- Helper Macros -->
<xacro:macro name="box_link" params="name origin size">
    <link name="${name}">
        <visual>
            <origin xyz="${origin}" rpy="0 0 0"/>
            <geometry>
                <box size="${size}"/>
            </geometry>
            <material name="blue">
                <color rgba="0 0 1 1"/>
            </material>
        </visual>
    </link>
</xacro:macro>

<xacro:macro name="revolute_joint" params="name parent child origin axis">
    <joint name="${name}" type="revolute">
        <parent link="${parent}"/>
        <child  link="${child}"/>

        <origin xyz="${origin}" rpy="0 0 0"/>

        <axis xyz="${axis}"/>

        <limit lower="-3.14" upper="3.14" effort="1" velocity="1"/>

    </joint>
</xacro:macro>

<!-- Actual URDF Definitions -->

<!-- Variable Definitions -->
<xacro:property name="thigh_length" value="0.22550"/>
<xacro:property name="thigh_offset" value="0.02300"/>

<xacro:property name="calf_length"  value="0.19625"/>
<xacro:property name="calf_offset"  value="0.06300"/>

<xacro:property name="foot_length"  value="0.14000"/>
<xacro:property name="foot_offset"  value="0.01600"/>

<!-- Link/Joint Definitions -->
<xacro:box_link
    name="hip"
    origin="0.025 0.0 0.0"
    size="0.05 0.05 0.05"/>

<xacro:box_link
    name="thigh"
    origin="${thigh_length/2} 0.0 0.0"
    size="${thigh_length} 0.05 0.05"/>

<xacro:box_link
    name="calf"
    origin="0.0 0.0 ${-calf_length/2}"
    size="0.05 0.05 ${calf_length}"/>

<xacro:box_link
    name="foot"
    origin="0.0 0.0 ${-foot_length/2}"
    size="0.05 0.05 ${foot_length}"/>

<xacro:revolute_joint
    name="hip_roll"
    parent="hip"
    child="thigh"
    origin="0.0 0.0 0.0"
    axis="1 0 0"/>

<xacro:revolute_joint
    name="hip_pitch"
    parent="thigh"
    child="calf"
    origin="${thigh_length} ${thigh_offset} 0.0"
    axis="0 1 0"/>

<xacro:revolute_joint
    name="knee_pitch"
    parent="calf"
    child="foot"
    origin="0.0 ${calf_offset} ${-calf_length}"
    axis="0 1 0"/>

</robot>
