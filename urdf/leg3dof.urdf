<?xml version="1.0"?>
<robot name="leg3dof">


<!-- Example of a link with visual data
  <link name="link_name">
    <visual>
      <origin xyz="X Y Z" rpy="ROLL PITCH YAW"/>
      <geometry>
        <box size="X_size Y_size Z_size"/>
      </geometry>
      <material name="color_name">
        <color rgba="R G B A"/>
      </material>
    </visual>
  </link>
-->

  <!--
    The origin of each link is moved along its axis by half of its
    x-size so that the link visually rotates about the tip of the box.
    This is necessary because visual boxes are positioned about their center.
  -->


  <!-- Link Definitions -->


  <!-- First link -->
  <link name="link1">
    <visual>
      <origin xyz="0.025 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
  </link>

  <!-- Second link -->
  <link name="link2">
    <visual>
      <origin xyz="0.11175 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.2235 0.05 0.05"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>
  </link>

  <!-- Third link -->
  <link name="link3">
    <visual>
      <origin xyz="0.097125 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.19425 0.05 0.05"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
  </link>

  <!-- End-effector -->
  <link name="foot">
    <visual>
      <origin xyz="0.07 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.140 0.05 0.05"/>
      </geometry>
      <material name="purple">
        <color rgba="1 0 1 1"/>
      </material>
    </visual>
  </link>

  <!-- Represents the very tip of the last link -->
  <link name="toe">
    <visual>
      <origin xyz="-0.025 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
      <material name="cyan">
        <color rgba="0 1 1 1"/>
      </material>
    </visual>
  </link>


  <!-- Joint Definitions -->


  <!-- Joint 1 -->
  <joint name="joint1" type="continuous">
    <parent link="link1"/>
    <child  link="link2"/>

    <origin xyz="0 0 0" rpy="0 0 0"/>

    <axis xyz="1 0 0"/>
  </joint>

  <!-- Joint 2 -->
  <joint name="joint2" type="continuous">
    <parent link="link2"/>
    <child  link="link3"/>

    <origin xyz="0.2235 0.04241 0" rpy="0 0 0"/>

    <axis xyz="0 1 0"/>
  </joint>

  <!-- Joint 3 -->
  <joint name="joint3" type="continuous">
    <parent link="link3"/>
    <child  link="foot"/>

    <origin xyz="0.19425 0.069 0" rpy="0 0 0"/>

    <axis xyz="0 1 0"/>
  </joint>

  <!-- Fixed joint that represents the final length of last link -->
  <joint name="footToToe" type="fixed">
    <parent link="foot"/>
    <child  link="toe"/>

    <origin xyz="0.140 0 0"/>
  </joint>

</robot>

